# Copy to .env and fill in. Get a key at https://aistudio.google.com/apikey
GOOGLE_API_KEY=your-key-here

# Optional overrides (defaults shown)
# ARAG_GEN_MODEL=gemini-2.5-flash
# ARAG_REASONING_MODEL=gemini-2.5-pro
# ARAG_EMBED_MODEL=gemini-embedding-001
# ARAG_EMBED_DIM=1536
# ARAG_INDEX_DIR=.arag_index

# ── Database ─────────────────────────────────────────────────────────────────
POSTGRES_USER=bakeryuser
POSTGRES_PASSWORD=bakerypass
POSTGRES_DB=bakerydb

# ── Langfuse Cloud ────────────────────────────────────────────────────────────
# Get keys at https://cloud.langfuse.com → Project Settings → API Keys
LANGFUSE_PUBLIC_KEY=lf-pk-...
LANGFUSE_SECRET_KEY=lf-sk-...
LANGFUSE_HOST=https://cloud.langfuse.com
