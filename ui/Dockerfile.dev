FROM node:26.3.1-bookworm-slim

WORKDIR /app

# Install deps into the image so the named-volume mount gets them on first run.
COPY package.json package-lock.json ./
RUN npm ci

EXPOSE 3000

ENV NEXT_TELEMETRY_DISABLED=1 \
    WATCHPACK_POLLING=true \
    CHOKIDAR_USEPOLLING=true

# The node_modules named volume persists across rebuilds, so reconcile it with
# the current lockfile on each start. This is a fast no-op when already in sync
# and picks up newly added deps without manually resetting the volume.
CMD ["sh", "-c", "npm install && npm run dev"]
